# --- VCS / tooling ---
.git
.github
.vscode
.idea
.ruff_cache

# --- deps (reinstalled inside the image) ---
node_modules

# --- secrets: NEVER copy env files into the build context ---
.env
.env.*
*.env

# --- vercel / local-only ---
.vercel
.vercelignore
*.log
_capture

